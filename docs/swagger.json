{
  "openapi": "3.0.0",
  "info": {
    "title": "Eventful API",
    "version": "1.0.0",
    "description": "Eventful backend API"
  },
  "servers": [
    {
      "url": "http://localhost:5000"
    }
  ],
  "paths": {
    "/api/v1/auth/register": {
      "post": {
        "summary": "Register user",
        "tags": ["Auth"]
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "summary": "Login user",
        "tags": ["Auth"]
      }
    },
    "/api/v1/events": {
      "get": {
        "summary": "Get public events",
        "tags": ["Events"]
      },
      "post": {
