    "/api/v1/tickets/verify": {
      "post": {
        "summary": "Verify ticket",
        "tags": ["Tickets"]
      }
    },
    "/api/v1/users/me": {
      "get": {
        "summary": "Get profile",
        "tags": ["Users"]
      },
      "patch": {
        "summary": "Update profile",
        "tags": ["Users"]
      }
    },
    "/api/v1/analytics/dashboard": {
      "get": {
        "summary": "Get dashboard analytics",
        "tags": ["Analytics"]
      }
